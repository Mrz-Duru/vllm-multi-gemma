# ── Required ──
MODEL_NAME=gemma2-cosmos          # Shortcut or full HF repo ID
HF_TOKEN=hf_your_token_here      # HuggingFace access token (for gated models)

# ── Optional (defaults shown) ──
PORT=8000
MAX_MODEL_LEN=4096                # Reduce for 12B models on 32GB GPU
GPU_MEMORY_UTILIZATION=0.92       # Leave some headroom
DTYPE=bfloat16                    # bfloat16 or float16
VLLM_EXTRA_ARGS=                  # Additional vllm flags, e.g. --enforce-eager

# ── Model shortcuts ──
# gemma2-cosmos  -> ytu-ce-cosmos/turkish-gemma2-9b-it
# gemma3-12b     -> google/gemma-3-12b-it
# gemma4-12b     -> google/gemma-4-12b-it
#
# Or use any full HuggingFace repo ID:
# MODEL_NAME=organization/model-name
